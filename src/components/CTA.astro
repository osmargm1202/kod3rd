    line-height: 1.2;
    margin-bottom: 1rem;
  }

  .cta__subheading {
    font-size: 1.15rem;
    opacity: 0.9;
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .cta {
      padding: 4rem 1rem;
