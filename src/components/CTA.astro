---
import site from '@/data/site.json';
---

<section class="cta animate-fade-in">
  <div class="cta__bg-wrap">
    <div class="cta__container">
      <div class="cta__hero">
        <div class="cta__overlay"></div>
        <div class="cta__content">
          <p class="cta__intro">No lo pienses</p>
          <h2 class="cta__heading">Creamos soluciones que hablan por ti</h2>
          <p class="cta__subheading">Unimos creatividad + tecnología para transformar ideas</p>
        </div>
      </div>
    </div>
  </div>

  <div class="cta__follow">
    <img
      src="/assets/images/Codigo.webp"
      alt="Kod3rd código"
      class="cta__side-image"
      loading="lazy"
    />

    <div class="cta__follow-panel">
      <h3 class="cta__follow-title">SIGUENOS</h3>
      <p class="cta__follow-text">
        ¿Todavía no nos sigues en Instagram?<br /> Conoce nuestros proyectos más recientes y contáctanos
        directamente!
      </p>
      <a
        href={site.instagram}
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn--primary cta__follow-button"
      >
        Follow
      </a>
    </div>

    <img
      src="/assets/images/Reunion.webp"
      alt="Kod3rd reunión"
      class="cta__side-image"
      loading="lazy"
    />
  </div>
</section>

<style>
  .cta {
    padding: 6rem 1rem;
    background: var(--color-primary);
  }

  .cta__bg-wrap {
    max-width: var(--container-max);
    margin: 0 auto;
  }

  .cta__container {
    border: 1px solid var(--color-border);
    border-radius: 40px;
    overflow: hidden;
  }

  .cta__hero {
    position: relative;
    background-image: url('/assets/images/Microservicio.webp');
    background-position: center center;
    background-repeat: no-repeat;
    background-size: cover;
    padding: 80px 40px;
    text-align: center;
    color: var(--color-text);
  }

  .cta__overlay {
    position: absolute;
    inset: 0;
    background-color: rgba(0, 0, 0, 0.5);
  }

  .cta__content {
    position: relative;
    z-index: 1;
    max-width: 648px;
    margin: 0 auto;
  }

  .cta__intro {
    font-family: var(--font-primary);
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 3px;
    margin-bottom: 1rem;
    opacity: 0.7;
  }

  .cta__heading {
    font-family: var(--font-secondary);
    font-size: 2.5rem;
    line-height: 1.2;
    margin-bottom: 1rem;
  }

  .cta__subheading {
    font-family: var(--font-primary);
    font-size: var(--text-body-size);
    opacity: 0.85;
    line-height: var(--text-body-lh);
    letter-spacing: var(--text-body-ls);
  }

  .cta__follow {
    max-width: var(--container-max);
    margin: 1.5rem auto 0;
    display: grid;
    grid-template-columns: minmax(140px, 1fr) minmax(320px, 1.8fr) minmax(140px, 1fr);
    gap: 24px;
    align-items: stretch;
  }

  .cta__side-image {
    width: 100%;
    max-width: 280px;
    margin: 0 auto;
    border-radius: 40px;
    object-fit: cover;
    aspect-ratio: 1 / 1;
    border: 1px solid var(--color-border);
  }

  .cta__follow-panel {
    background: var(--color-secondary);
    border: 1px solid var(--color-border);
    border-radius: 40px;
    text-align: center;
    padding: 56px 32px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1.2rem;
    min-height: 100%;
  }

  .cta__follow-title {
    font-family: var(--font-primary);
    font-size: 1.2rem;
    text-transform: uppercase;
    letter-spacing: 3px;
    opacity: 0.8;
  }

  .cta__follow-text {
    font-family: var(--font-primary);
    font-size: var(--text-body-size);
    line-height: 1.45;
    opacity: 0.85;
  }

  .cta__follow-button {
    width: fit-content;
    margin: 0 auto;
  }

  @media (max-width: 1024px) {
    .cta__follow {
      grid-template-columns: 1fr;
      gap: 24px;
      max-width: 620px;
    }

    .cta__side-image {
      max-width: 620px;
      margin: 0 auto;
      aspect-ratio: 4 / 3;
      width: min(100%, 420px);
    }

    .cta__follow-panel {
      max-width: 620px;
      margin: 0 auto;
      min-height: auto;
    }
  }

  @media (max-width: 768px) {
    .cta {
      padding: 4rem 1rem;
    }

    .cta__hero {
      padding: 40px 20px;
    }

    .cta__heading {
      font-size: 1.8rem;
    }

    .cta__follow {
      margin-top: 1rem;
      gap: 16px;
    }

    .cta__follow-panel {
      padding: 36px 16px;
    }

    .cta__follow-text {
      font-size: 0.95rem;
    }
  }
</style>
