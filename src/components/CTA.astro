<section class="cta animate-fade-in">
  <div class="cta__container">
    <div class="cta__hero">
      <div class="cta__overlay"></div>
      <div class="cta__content">
        <p class="cta__intro">No lo pienses</p>
        <h2 class="cta__heading">Creamos soluciones que hablan por ti</h2>
        <p class="cta__subheading">Unimos creatividad + tecnología para transformar ideas</p>
      </div>
    </div>
  </div>
</section>

<style>
  .cta {
    padding: 6rem 1rem;
    background: var(--color-primary);
  }

  .cta__container {
    max-width: var(--container-max);
    margin: 0 auto;
    border: 1px solid var(--color-border);
    border-radius: 40px;
    overflow: hidden;
  }

  .cta__hero {
    position: relative;
    background-image: url('/assets/images/Microservicio.webp');
    background-position: center center;
    background-repeat: no-repeat;
    background-size: cover;
    padding: 80px 40px;
    text-align: center;
    color: var(--color-text);
  }

  .cta__overlay {
    position: absolute;
    inset: 0;
    background-color: rgba(0, 0, 0, 0.92);
  }

  .cta__content {
    position: relative;
    z-index: 1;
    max-width: 648px;
    margin: 0 auto;
  }

  .cta__intro {
    font-family: var(--font-primary);
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 3px;
    margin-bottom: 1rem;
    opacity: 0.7;
  }

  .cta__heading {
    font-family: var(--font-secondary);
    font-size: 2.5rem;
    line-height: 1.2;
    margin-bottom: 1rem;
  }

  .cta__subheading {
    font-family: var(--font-primary);
    font-size: var(--text-body-size);
    opacity: 0.85;
    line-height: var(--text-body-lh);
    letter-spacing: var(--text-body-ls);
  }

  @media (max-width: 768px) {
    .cta {
      padding: 4rem 1rem;
    }

    .cta__hero {
      padding: 40px 20px;
    }

    .cta__heading {
      font-size: 1.8rem;
    }
  }
</style>
