---
import about from '@/data/about.json';
import values from '@/data/values.json';
---

<section id="SOBRE" class="section about">
  <div class="container">
    <div class="about__grid">
      <div class="about__values-col">
        {values.slice(0, 2).map((value, i) => (
          <div class={`about__value-card animate-slide-up delay-${(i * 200) + 200}`}>
            <h3 class="about__value-title">{value.title}</h3>
            <p class="about__value-text">{value.description}</p>
          </div>
        ))}
      </div>
      <div class="about__main animate-slide-up">
        <h2 class="section__title">{about.heading}</h2>
        <p class="about__intro">{about.intro}</p>
        <p class="about__description">{about.description}</p>
      </div>
      <div class="about__values-col">
        {values.slice(2, 4).map((value, i) => (
          <div class={`about__value-card animate-slide-up delay-${(i * 200) + 200}`}>
            <h3 class="about__value-title">{value.title}</h3>
            <p class="about__value-text">{value.description}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .about {
    background: var(--color-secondary);
  }

  .about__grid {
    display: grid;
    grid-template-columns: 1fr 1.5fr 1fr;
    gap: 2rem;
    align-items: start;
  }

  .about__main {
    text-align: center;
    padding: 2rem 0;
  }

  .about__intro {
    font-family: var(--font-secondary);
    font-size: 1.5rem;
    color: var(--color-text);
    margin-bottom: 1.5rem;
    line-height: 1.4;
  }

  .about__description {
    font-family: var(--font-primary);
    font-size: var(--text-body-size);
    font-weight: 400;
    line-height: var(--text-body-lh);
    letter-spacing: var(--text-body-ls);
    color: var(--color-text);
    max-width: var(--content-max);
    margin: 0 auto;
  }

  .about__values-col {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .about__value-card {
    padding: 1.5rem;
    border: 1px solid var(--color-accent);
    border-radius: 10px;
  }

  .about__value-title {
    font-family: var(--font-alt);
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
  }

  .about__value-text {
    font-family: var(--font-primary);
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--color-text);
    opacity: 0.85;
  }

  @media (max-width: 768px) {
    .about__grid {
      grid-template-columns: 1fr;
    }

    .about__values-col {
      flex-direction: row;
      flex-wrap: wrap;
    }

    .about__value-card {
      flex: 1 1 calc(50% - 0.75rem);
    }
  }
</style>
