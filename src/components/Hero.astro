---
import hero from '@/data/hero.json';
---

<section id="INICIO" class="hero animate-fade-in">
  <div class="hero__card">
    <div class="hero__content">
      <h1 class="hero__heading">{hero.heading}</h1>
      <p class="hero__subheading">{hero.subheading}</p>
    </div>
    <div class="hero__columns">
      <div class="hero__column">
        <p>{hero.paragraphs[0]}</p>
      </div>
      <div class="hero__divider"></div>
      <div class="hero__column">
        <p>{hero.paragraphs[1]}</p>
      </div>
      <div class="hero__divider"></div>
      <div class="hero__column">
        <p>{hero.paragraphs[2]}</p>
      </div>
    </div>
    <div class="hero__ctas">
      <a href={hero.primaryCta.url} class="btn btn--primary">{hero.primaryCta.text}</a>
      <a href={hero.secondaryCta.url} target="_blank" rel="noopener noreferrer" class="btn btn--secondary">{hero.secondaryCta.text}</a>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 8rem 40px 4rem;
    position: relative;
    overflow: hidden;
    background: var(--color-secondary);
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: url('/assets/images/hero-bg.webp') center center / cover no-repeat;
    opacity: 0.3;
    z-index: 0;
  }

  .hero__card {
    position: relative;
    z-index: 1;
    background: rgba(19, 6, 6, 0.92);
    border: 1px solid var(--color-border);
    border-radius: 40px;
    padding: 100px 40px 80px;
    max-width: 1200px;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 80px;
  }

  .hero__content {
    text-align: center;
  }

  .hero__heading {
    font-family: var(--font-primary);
    font-size: 4.2vw;
    font-weight: 700;
    line-height: 1.2em;
    color: var(--color-text);
    margin-bottom: 1rem;
  }

  .hero__subheading {
    font-family: var(--font-primary);
    font-size: var(--text-body-size);
    font-weight: 400;
    line-height: var(--text-body-lh);
    letter-spacing: var(--text-body-ls);
    color: var(--color-text);
    max-width: var(--content-max);
    margin: 0 auto;
  }

  .hero__columns {
    display: flex;
    align-items: stretch;
    gap: 0;
    justify-content: center;
  }

  .hero__column {
    flex: 0 0 30%;
    text-align: center;
    padding: 20px 40px;
  }

  .hero__column p {
    font-family: var(--font-primary);
    font-size: var(--text-body-size);
    font-weight: 400;
    line-height: var(--text-body-lh);
    letter-spacing: var(--text-body-ls);
    color: var(--color-text);
    margin: 0;
  }

  .hero__divider {
    width: 1px;
    background: var(--color-accent);
    flex-shrink: 0;
  }

  .hero__ctas {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  @media (max-width: 768px) {
    .hero {
      padding: 6rem 1rem 2rem;
    }

    .hero__card {
      padding: 40px 20px;
      border-radius: 24px;
      gap: 40px;
    }

    .hero__heading {
      font-size: 2.2rem;
    }

    .hero__columns {
      flex-direction: column;
      gap: 1rem;
    }

    .hero__column {
      flex: 1 1 100%;
      padding: 10px 20px;
    }

    .hero__divider {
      width: 100%;
      height: 1px;
    }
  }
</style>
